<script>
var clS=[false,false,false,false,false,false];
function clTog(i){
  clS[i]=!clS[i];
  document.getElementById('cc'+i).className='cl-check'+(clS[i]?' done':'');
  document.getElementById('cl'+i).className='cl-label'+(clS[i]?' done':'');
  var n=clS.filter(Boolean).length;
  var p=Math.round(n/6*100);
  document.getElementById('cl-bar').style.width=p+'%';
  document.getElementById('cl-counter').textContent=n+' de 6 completados';
  document.getElementById('cl-pct').textContent=p+' %';
  document.getElementById('cl-done').style.display=n===6?'block':'none';
}
</script>

