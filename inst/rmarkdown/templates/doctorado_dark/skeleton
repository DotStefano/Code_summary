```{css custom-styles, echo=FALSE}
/* ── Soft Neon Overlay – Midnight UI ────────────────────────────────────── */
:root {
  --bg      : #121317;   /* Midnight UI                  */
  --bg2     : #1A1B20;   /* superficie ligeramente clara */
  --bg3     : #22232A;   /* superficie hover / thead     */
  --border  : #2E3040;
  --texto   : #F7F9FC;   /* Cloud White                  */
  --texto2  : #6B6E7A;   /* Slate Gray                   */
  --acento  : #B0FFDC;   /* Mint Glow                    */
  --kw      : #FFB0BA;   /* Blush Pink  – keywords       */
  --fn      : #B0FFDC;   /* Mint Glow   – funciones      */
  --str     : #FFF3A1;   /* Highlight Yellow – strings   */
  --num     : #FFB0BA;   /* Blush Pink  – números        */
  --type    : #B0FFDC;   /* Mint Glow   – tipos          */
  --comment : #6B6E7A;   /* Slate Gray  – comentarios    */
}

/* ── Base ────────────────────────────────────────────────────────────────── */
body, .main-container {
  background-color: var(--bg) !important;
  color: var(--texto);
  font-family: Georgia, "Times New Roman", serif;
}

/* ── Encabezados ─────────────────────────────────────────────────────────── */
h1, h1.title {
  color: var(--acento);
  font-weight: 700;
  letter-spacing: -0.3px;
}
h2 {
  color: var(--texto);
  font-weight: 600;
  border-bottom: 1.5px solid var(--border);
  padding-bottom: 4px;
}
h3 { color: var(--texto2); font-weight: 600; }

/* ── TOC ─────────────────────────────────────────────────────────────────── */
#TOC {
  background-color: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 3px;
  padding: 12px;
}
#TOC a       { color: var(--texto2) !important; font-weight: 400; }
#TOC a:hover { color: var(--texto)  !important; text-decoration: none; }
#TOC li.active > a {
  color: var(--acento) !important;
  font-weight: 600;
  border-left: 2px solid var(--acento);
  padding-left: 6px;
  background: transparent !important;
}

/* ── Código ──────────────────────────────────────────────────────────────── */
pre {
  background-color: var(--bg2) !important;
  border: 1px solid var(--border);
  border-left: 3px solid var(--acento);
  border-radius: 3px;
  padding: 14px;
  font-family: "Fira Code", "Courier New", monospace;
  font-size: 0.88em;
}
pre code { background-color: transparent !important; color: var(--texto); }

.kw           { color: var(--kw)      !important; font-weight: 600; }
.fu           { color: var(--fn)      !important; }
.st           { color: var(--str)     !important; }
.dv, .fl      { color: var(--num)     !important; }
.kc           { color: var(--num)     !important; }
.dt           { color: var(--type)    !important; }
.co           { color: var(--comment) !important; font-style: italic; }
.op           { color: var(--texto2)  !important; }

code:not([class]) {
  background-color: var(--bg2);
  color: var(--kw);
  border: 1px solid var(--border);
  border-radius: 2px;
  padding: 1px 5px;
  font-size: 0.90em;
  font-family: "Fira Code", "Courier New", monospace;
}

/* ── Details ─────────────────────────────────────────────────────────────── */
details {
  background-color: var(--bg2);
  border-left: 3px solid var(--border);
  padding: 8px 14px;
  margin: 10px 0;
}
summary       { color: var(--texto2); font-weight: 600; cursor: pointer; user-select: none; }
summary:hover { color: var(--acento); }
details div   { color: var(--texto2) !important; margin-top: 6px; }

/* ── Blockquote ──────────────────────────────────────────────────────────── */
blockquote {
  border-left: 3px solid var(--acento);
  background-color: var(--bg2);
  padding: 10px 16px;
  color: var(--texto2);
  font-style: italic;
}

/* ── Tablas ──────────────────────────────────────────────────────────────── */
table { border-collapse: collapse; width: 100%; margin: 14px 0; font-size: 0.95em; }
thead tr                 { background-color: var(--bg3); color: var(--texto); font-weight: 600; }
tbody tr:nth-child(even) { background-color: var(--bg2); }
tbody tr:nth-child(odd)  { background-color: var(--bg);  }
td, th { padding: 8px 12px; border: 1px solid var(--border); color: var(--texto); }
```

